rules_version = '2';

/**
 * IRS KENYA - Security Rules
 * SOURCE OF TRUTH: This file is the definitive source for Firestore security.
 * Sync this to Firebase Console via: firebase deploy --only firestore:rules
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Users: Only the owner can access their profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Found IDs: Publicly searchable, secure reporting/updating
    match /found_ids/{id} {
      allow read: if true; 
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    // 3. ID Watchlist: Private owner access, system-wide matching
    match /id_watch_list/{watchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        request.resource.data.status == "notified"
      );
    }
  }
}
